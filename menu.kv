<MenuWidget>:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.8
        Rectangle:
            size: self.size
            pos: self.pos

    Label:
        text: root.parent.menu_title
        font_size: dp(56)
        font_name: 'fonts/Sackers-Gothic-Std-Light.ttf'
        halign: 'center'
        text_size: self.size
        pos_hint: {"center_x": 0.5, "center_y": 0.62}

    Button:
        text: root.parent.menu_button_title
        font_size: dp(28)
        font_name: 'fonts/Eurostile.ttf'
        pos_hint: {"center_x": 0.5, "center_y": 0.32}
        size_hint: 0.28, 0.16
        background_normal: ''
        background_color: 1, 0.3, 0.4, 0.9
        on_press: root.parent.on_menu_button_pressed()
